{
    "manifest_version": 3,
    "name": "SpamX",
    "description": "YouTube spam comment detection.",
    "version": "1",
    "background": {
        "service_worker": "scripts/background.js"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://www.youtube.com/*",
        "https://spamx-spamx.hf.space/*",
        "https://backend-delta-roan-60.vercel.app/*",
        "http://localhost:3001/*",
        "http://localhost:5174/*",
        "http://localhost:5175/*",
        "http://127.0.0.1:8000/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "scripts/api.js",
                "scripts/ui.js",
                "scripts/DetectorEngine.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "logo.png",
            "32": "logo.png",
            "48": "logo.png",
            "128": "logo.png"
        }
    },
    "icons": {
        "16": "logo.png",
        "32": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
    }
}